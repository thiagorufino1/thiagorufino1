{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
    "manifestVersion": "1.25",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Thiago AI Solutions",
        "websiteUrl": "https://github.com/thiagorufino1",
        "privacyUrl": "https://github.com/thiagorufino1/privacy",
        "termsOfUseUrl": "https://github.com/thiagorufino1/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "M365 Agent${{APP_NAME_SUFFIX}}",
        "full": "Modern AI Agent for Microsoft 365"
    },
    "description": {
        "short": "Efficient AI Assistant for Microsoft 365 apps.",
        "full": "M365 Agent is a professional AI assistant designed to boost productivity across Microsoft 365 using advanced language models and real-time streaming."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "bots": [
        {
            "botId": "${{BOT_ID}}",
            "scopes": [
                "team",
                "groupChat",
                "personal"
            ],
            "supportsFiles": false,
            "isNotificationOnly": false,
            "commandLists": [
                {
                    "scopes": [
                        "personal"
                    ],
                    "commands": [
                        {
                            "title": "How can you help me?",
                            "description": "How can you help me?"
                        },
                        {
                            "title": "How to develop agent for Teams?",
                            "description": "How can I develop agents with Microsoft 365 Agents Toolkit?"
                        }
                    ]
                }
            ]
        }
    ],
    "composeExtensions": [],
    "configurableTabs": [],
    "staticTabs": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "ai-trc.openai.azure.com"
    ]
}
