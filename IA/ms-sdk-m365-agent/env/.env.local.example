# Copie este arquivo para .env.local e preencha os valores.
# Este arquivo é commitado no git — não coloque secrets aqui.

# Built-in (não altere)
TEAMSFX_ENV=local
APP_NAME_SUFFIX=local

# App identity / branding
APP_SHORT_NAME=M365 Agent
APP_FULL_NAME=Modern AI Agent for Microsoft 365
APP_DESCRIPTION_SHORT=Efficient AI Assistant for Microsoft 365 apps.
APP_DESCRIPTION_FULL=M365 Agent is a professional AI assistant designed to boost productivity across Microsoft 365 using advanced language models and real-time streaming.
APP_DEVELOPER_NAME=Your Company Name
APP_DEVELOPER_WEBSITE=https://yourwebsite.com
APP_DEVELOPER_PRIVACY_URL=https://yourwebsite.com/privacy
APP_DEVELOPER_TERMS_URL=https://yourwebsite.com/terms

# Preenchido automaticamente pelo toolkit ao provisionar (não edite manualmente)
BOT_ID=
BOT_OBJECT_ID=
BOT_DOMAIN=
BOT_ENDPOINT=
TEAMS_APP_ID=
TEAMS_APP_TENANT_ID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=
