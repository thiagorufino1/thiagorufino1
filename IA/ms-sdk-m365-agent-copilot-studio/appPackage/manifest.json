{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
    "manifestVersion": "1.25",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "${{APP_DEVELOPER_NAME}}",
        "websiteUrl": "${{APP_DEVELOPER_WEBSITE}}",
        "privacyUrl": "${{APP_DEVELOPER_PRIVACY_URL}}",
        "termsOfUseUrl": "${{APP_DEVELOPER_TERMS_URL}}"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "${{APP_SHORT_NAME}}${{APP_NAME_SUFFIX}}",
        "full": "${{APP_FULL_NAME}}"
    },
    "description": {
        "short": "${{APP_DESCRIPTION_SHORT}}",
        "full": "${{APP_DESCRIPTION_FULL}}"
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "bots": [
        {
            "botId": "${{BOT_ID}}",
            "scopes": [
                "team",
                "groupChat",
                "personal"
            ],
            "supportsFiles": false,
            "isNotificationOnly": false,
            "commandLists": [
                {
                    "scopes": [
                        "personal"
                    ],
                    "commands": [
                        {
                            "title": "How can you help me?",
                            "description": "How can you help me?"
                        },
                        {
                            "title": "How to develop agent for Teams?",
                            "description": "How can I develop agents with Microsoft 365 Agents Toolkit?"
                        }
                    ]
                }
            ]
        }
    ],
    "composeExtensions": [],
    "configurableTabs": [],
    "staticTabs": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": [
        "ai-trc.openai.azure.com"
    ]
}
